# ══════════════════════════════════════════════════════════════════════════════
# Bot Restaurante — Variáveis de Ambiente para Produção
# Copie este arquivo para .env e preencha todos os valores marcados com ⚠️
# ══════════════════════════════════════════════════════════════════════════════

# ── Banco de Dados PostgreSQL ─────────────────────────────────────────────────

# ⚠️ Usuário do banco — evite usar "user" em produção
DB_USER=botrestaurante

# ⚠️ Senha forte do banco — gere com: openssl rand -hex 32
DB_PASSWORD=TROQUE_POR_SENHA_FORTE

# Nome do banco de dados (pode manter o padrão)
DB_NAME=botrestaurante

# ── Bot Node.js ───────────────────────────────────────────────────────────────

# ⚠️ Chave da API Anthropic Claude
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXX

# ⚠️ Token secreto para proteger as rotas /admin/* e /onboarding/*
# Gere com: openssl rand -hex 32
ADMIN_TOKEN=TROQUE_POR_TOKEN_SECRETO

# ⚠️ URL pública do servidor (sem barra final)
# Exemplo: https://meudominio.com ou http://IP_DA_VPS
BOT_PUBLIC_URL=https://meudominio.com

# Porta interna do bot (não precisa alterar — o nginx faz o roteamento)
PORT=3000

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────

# ⚠️ Chave de autenticação da Evolution API
# Gere com: openssl rand -hex 24
# DEVE ser igual em evolution-api e bot
EVOLUTION_API_KEY=TROQUE_POR_CHAVE_EVOLUTION

# URL interna da Evolution API (via Docker network — não altere)
EVOLUTION_API_URL=http://evolution-api:8080

# ── Strapi CMS ────────────────────────────────────────────────────────────────

# ⚠️ URL onde o Strapi está rodando
# Se rodar na mesma VPS fora do Docker: http://localhost:1337
# Se em servidor separado: https://cms.meudominio.com
STRAPI_URL=http://localhost:1337

# ⚠️ API Token do Strapi com permissão Read-only
# Gere em: Strapi Admin → Settings → API Tokens → Create new API Token
STRAPI_TOKEN=TROQUE_PELO_TOKEN_DO_STRAPI

# ── Strapi — Variáveis internas (preencher no .env dentro de strapi/) ─────────
# As variáveis abaixo são usadas pelo Strapi, não pelo docker-compose.
# Documente aqui para referência ao configurar o Strapi manualmente.
#
# APP_KEYS=chave1,chave2,chave3,chave4   ← gere 4 valores com: openssl rand -base64 16
# API_TOKEN_SALT=valor                   ← openssl rand -hex 16
# ADMIN_JWT_SECRET=valor                 ← openssl rand -hex 32
# TRANSFER_TOKEN_SALT=valor              ← openssl rand -hex 16
# JWT_SECRET=valor                       ← openssl rand -hex 32
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
