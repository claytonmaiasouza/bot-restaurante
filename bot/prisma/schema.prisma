// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurante {
  id           String      @id @default(uuid())
  nome         String
  slugWhatsapp String      @unique
  donoWhatsapp String
  strapiId     Int?        @unique // legado — null para restaurantes criados pelo painel
  ativo        Boolean     @default(true)
  moeda        String      @default("R$")
  taxaEntrega  Float       @default(0)
  email               String?     @unique
  senhaHash           String?
  horarioAtendimento  String?     // JSON: { ativo, descricao, dias: { "0": { aberto, abertura, fechamento }, ... } }
  cardapioPdfUrl      String?
  dadosTransferencia  String?     // Dados para PIX/transferência exibidos ao cliente
  sessoes              Sessao[]
  pedidos              Pedido[]
  categorias           Categoria[]
  programasFidelidade  ProgramaFidelidade[]
  motoboys             Motoboy[]
  createdAt            DateTime    @default(now())
}

model Categoria {
  id            String      @id @default(uuid())
  nome          String
  ordem         Int         @default(0)
  restauranteId String
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  produtos      Produto[]
  createdAt     DateTime    @default(now())
}

model Produto {
  id          String    @id @default(uuid())
  nome        String
  descricao   String?
  preco       Float     @default(0)
  ativo       Boolean   @default(true)
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  tamanhos    Tamanho[]
  createdAt   DateTime  @default(now())
}

model Tamanho {
  id            String  @id @default(uuid())
  nome          String
  preco         Float
  precoComBorda Float?
  produtoId     String
  produto       Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

model Sessao {
  id              String      @id @default(uuid())
  clienteNumero   String // número WhatsApp do cliente
  clienteNome     String?
  restauranteId   String
  restaurante     Restaurante @relation(fields: [restauranteId], references: [id])
  estado          String      @default("INICIO")
  // estados: INICIO, VENDO_CARDAPIO, ADICIONANDO_ITEM, CONFIRMANDO_PEDIDO, AGUARDANDO_LOCALIZACAO, FINALIZADO
  carrinho        Json        @default("[]")
  botPausado          Boolean     @default(false)
  localizacaoPendente String?
  lembreteEnviado     Boolean     @default(false)
  mensagens           Mensagem[]
  pedido              Pedido?
  ultimaAtividade DateTime    @default(now())
  createdAt       DateTime    @default(now())
}

model Mensagem {
  id        String   @id @default(uuid())
  sessaoId  String
  sessao    Sessao   @relation(fields: [sessaoId], references: [id])
  role      String // "cliente" ou "bot"
  conteudo  String
  createdAt DateTime @default(now())
}

model Pedido {
  id            String      @id @default(uuid())
  sessaoId      String      @unique
  sessao        Sessao      @relation(fields: [sessaoId], references: [id])
  restauranteId String
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id])
  clienteNumero String
  clienteNome   String?
  itens         Json // [{nome, preco, quantidade}]
  total         Float
  localizacao      String? // link Google Maps ou texto do endereço
  metodoPagamento  String? // Dinheiro | Cartão | Transferência
  status        String      @default("NOVO") // NOVO, CONFIRMADO, PAGO, PREPARANDO, SAIU_PARA_ENTREGA, PRONTO_PARA_RETIRADA, ENTREGUE, CANCELADO
  pago          Boolean     @default(false)
  motoboyId     String?     // ID do motoboy despachado (sem FK para preservar histórico)
  motoboyNome   String?     // nome denormalizado para exibição
  createdAt     DateTime    @default(now())
}

model ClienteFidelidade {
  id           String    @id @default(uuid())
  numero       String    @unique // WhatsApp do cliente
  nome         String?
  totalPedidos Int       @default(0)
  totalGasto   Float     @default(0)
  ultimoPedido DateTime?
  restaurantes Json      @default("[]") // histórico por restaurante
  createdAt    DateTime  @default(now())
}

model ProgramaFidelidade {
  id            String               @id @default(uuid())
  restauranteId String
  restaurante   Restaurante          @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  nome          String
  descricao     String?
  tipo          String               @default("PEDIDOS") // PEDIDOS | VALOR
  meta          Float                // ex: 10 pedidos, ou R$ 500 em gastos
  ativo         Boolean              @default(true)
  resgates      ResgateFidelidade[]
  createdAt     DateTime             @default(now())
}

model ResgateFidelidade {
  id            String             @id @default(uuid())
  programaId    String
  programa      ProgramaFidelidade @relation(fields: [programaId], references: [id], onDelete: Cascade)
  clienteNumero String
  clienteNome   String?
  registradoPor String             @default("admin")
  createdAt     DateTime           @default(now())
}

model Motoboy {
  id            String      @id @default(uuid())
  nome          String
  telefone      String      // número WhatsApp (só dígitos)
  restauranteId String
  restaurante   Restaurante @relation(fields: [restauranteId], references: [id], onDelete: Cascade)
  ativo         Boolean     @default(true)
  createdAt     DateTime    @default(now())
}
