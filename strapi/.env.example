HOST=0.0.0.0
PORT=1337

# Geradas automaticamente — substitua por valores aleatórios em produção
# node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS=chave1base64,chave2base64,chave3base64,chave4base64
API_TOKEN_SALT=saltaleatorio
ADMIN_JWT_SECRET=jwtsecretadmin
TRANSFER_TOKEN_SALT=transfersalt
JWT_SECRET=jwtsecretpublico

# Banco de dados (padrão: SQLite)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Para usar PostgreSQL, comente o SQLite acima e descomente:
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=botrestaurante_strapi
# DATABASE_USERNAME=user
# DATABASE_PASSWORD=pass
# DATABASE_SSL=false
